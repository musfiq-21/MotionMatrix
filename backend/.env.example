# ============================================================================
# MotionMatrix Backend - Environment Configuration Example
# ============================================================================
# Copy this file to backend.env and fill in your actual values
# NEVER commit backend.env to version control
# ============================================================================

# Application
APP_NAME=MotionMatrix
APP_VERSION=1.0.0
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
TIMEZONE=UTC

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=motionmatrix
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=False

# JWT Security
JWT_SECRET_KEY=your-super-secret-key-minimum-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=True
SMTP_SSL=False
SMTP_FROM_EMAIL=noreply@motionmatrix.com
SMTP_FROM_NAME=MotionMatrix Support
EMAILS_ENABLED=False

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Admin defaults
ADMIN_EMAIL=admin@motionmatrix.com
ADMIN_PASSWORD=Admin@123456

# ML Service
ML_SERVER_URL=http://localhost:5000
ML_SERVICE_URL=http://localhost:6000

# Test Database
TEST_DB_NAME=motionmatrix_test
